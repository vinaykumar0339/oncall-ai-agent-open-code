{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "autoupdate": false,
  "default_agent": "oncall",
  "server": {
    "port": 4096
  },
  "provider": {
    "vymolmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Vymo LM Studio (local)",
      "options": {
        "baseURL": "http://172.16.19.156:4858/v1"
      },
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "Gemma 4-26b-a4b (local)"
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-4-e4b": {
          "name": "Gemma 4-e4b (local)"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "*": "deny"
    },
    "atlassian_*": "deny",
    "maestro-mcp_*": "deny",
    "bitbucket_*": "deny",
    "external_directory": {
      "~/vymo/**": "allow",
      "~/vymo/react-app/**": "allow",
      "~/vymo/android-base/**": "allow"
    }
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "bitbucket": {
      "type": "remote",
      "url": "http://localhost:3000/mcp",
      "enabled": true
    },
    "maestro-mcp": {
      "type": "local",
      "command": [
        "maestro",
        "mcp"
      ],
      "enabled": true
    }
  }
}
