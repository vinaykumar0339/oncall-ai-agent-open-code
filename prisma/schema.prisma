generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model TicketThread {
  ticketKey              String         @id @map("ticket_key")
  issueSummary           String         @map("issue_summary")
  opencodeSessionId      String?        @map("opencode_session_id")
  sessionTitle           String?        @map("session_title")
  runState               String         @default("idle") @map("run_state")
  platform               String?
  branchType             String?        @map("branch_type")
  branchName             String?        @map("branch_name")
  sourceBranch           String?        @map("source_branch")
  branchReason           String?        @map("branch_reason")
  lastProcessedCommentId String?        @map("last_processed_comment_id")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  pendingUpdates         PendingUpdate[]
  runs                   Run[]
  processedEvents        ProcessedEvent[]

  @@map("ticket_threads")
}

model ProcessedEvent {
  deliveryId  String      @id @map("delivery_id")
  ticketKey   String      @map("ticket_key")
  commentId   String?     @map("comment_id")
  eventType   String      @map("event_type")
  dedupeStatus String     @map("dedupe_status")
  processedAt DateTime    @default(now()) @map("processed_at")
  ticketThread TicketThread @relation(fields: [ticketKey], references: [ticketKey], onDelete: Restrict)

  @@index([ticketKey, processedAt(sort: Desc)], map: "processed_events_ticket_idx")
  @@map("processed_events")
}

model PendingUpdate {
  id           Int          @id @default(autoincrement())
  ticketKey    String       @map("ticket_key")
  eventType    String       @map("event_type")
  commentId    String?      @map("comment_id")
  authorName   String?      @map("author_name")
  visibility   String       @default("public")
  isControl    Boolean      @default(false) @map("is_control")
  payload      Json
  createdAt    DateTime     @default(now()) @map("created_at")
  mergedAt     DateTime?    @map("merged_at")
  mergedIntoRunId String?   @map("merged_into_run_id")
  ticketThread TicketThread @relation(fields: [ticketKey], references: [ticketKey], onDelete: Restrict)

  @@index([ticketKey, createdAt(sort: Asc)], map: "pending_updates_ticket_created_idx")
  @@map("pending_updates")
}

model Run {
  runId             String       @id @map("run_id")
  ticketKey         String       @map("ticket_key")
  opencodeSessionId String?      @map("opencode_session_id")
  currentStage      String?      @map("current_stage")
  status            String
  workflowStatus    String?      @map("workflow_status")
  lockOwner         String?      @map("lock_owner")
  lastCheckpoint    String?      @map("last_checkpoint")
  failureReason     String?      @map("failure_reason")
  startedAt         DateTime     @default(now()) @map("started_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  finishedAt        DateTime?    @map("finished_at")
  ticketThread      TicketThread @relation(fields: [ticketKey], references: [ticketKey], onDelete: Restrict)

  @@index([ticketKey, startedAt(sort: Desc)], map: "runs_ticket_started_idx")
  @@map("runs")
}
